# Oracle Database Configuration
# Format: host:port/service_name
DB_DSN=db:1521/FREEPDB1
DB_USER=system
DB_PASSWORD=YOUR_ORACLE_PASSWORD
# Optional: fallback host when running backend on the host machine instead of in Docker
DB_DSN_LOCAL_HOST=127.0.0.1

# Service ports
BACKEND_PORT=8000
FRONTEND_PORT=8501

# Root password for Oracle (used by Docker)
ORACLE_PWD=YOUR_ORACLE_PASSWORD
